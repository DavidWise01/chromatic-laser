KERNEL: REAL_OPTICAL_ARRAY_128
VERSION: 1.0
AUTHOR: David Wise + GPT-5.5 Thinking
MODE: SAFE_LOW_POWER_REFERENCE

GEOMETRY:
  TOTAL_EMITTERS = 128
  UPPER_BANK = 64
  LOWER_BANK = 64
  CENTER_NODE = CAPACITANCE_WELL_ANALOG
  PHASE_STEP = 0.001

SAFETY:
  NO_HIGH_POWER_BEAM_COMBINING
  NO_OPEN_COLLIMATED_ARRAY
  CURRENT_LIMIT_REQUIRED
  DUTY_LIMIT_REQUIRED
  ENCLOSURE_RECOMMENDED

STATE:
  -2 = SUBSPACE_LISTEN
  -1 = SAFE_HOLD
   0 = CENTER_REST
   1 = EMITTER_ARMED
   2 = PAIR_AGREEMENT
   3 = BLOOM_FRAME
   5 = COHERENCE_HOLD
   8 = ARRAY_ACTIVE

LOOP:
  OBSERVE_CENTER
  UPDATE_PHASE(0.001)
  SELECT_PAIR(upper[i], lower[i])
  DRIVE_BOUNDED_PWM
  MEASURE_RESPONSE
  CLAMP_NO_BLEED
  REPORT_COHERENCE
  REPEAT

FAILSAFE:
  IF overcurrent OR overtemp OR enclosure_open OR sensor_saturates:
      SET_ALL_PWM(0)
      STATE = -1
      REPORT_SAFE_HOLD
